WEB_PORT=1288
STORAGE_ROOT=/srv/Storage
APP_ROOT=/opt/storage-http-link-web
PUBLIC_HOST=home.rxotc.cn:1288
PUBLIC_SCHEME=http
DOWNLOADS_ENABLED=1
QBT_SERVICE=qbittorrent-nox
# qBittorrent WebUI 统计（可选；不开则仅显示 systemd 运行状态）
QBT_API_URL=http://127.0.0.1:8080
QBT_API_USERNAME=
QBT_API_PASSWORD=
DDNS_SERVICE=ddns-go.service
# ShareClip 与 1288 同进程，数据落盘路径（默认可不设置，与 install.sh 一致）
SHARECLIP_STORAGE_ROOT=/opt/storage-http-link-web/shareclip/storage
