  "patterns": [
    {
      "re": "^活跃 (\\d+) 个 · 最近完成 (\\d+) 个 · 总完成度 ([0-9.]+)%$",
      "to": "アクティブ $1 ・ 最近完了 $2 ・ 全体進捗 $3%"
    },
    {
      "re": "^来源速度：(.*)$",
      "to": "ソース速度: $1"
    },
    {
      "re": "^保存失败：(.*)$",
      "to": "保存失敗: $1"
    },
    {
      "re": "^配置加载失败：(.*)$",
      "to": "設定読み込み失敗: $1"
    },
    {
      "re": "^加载失败：(.*)$",
      "to": "読み込み失敗: $1"
    },
    {
      "re": "^切换失败：(.*)$",
      "to": "切替失敗: $1"
    },
    {
      "re": "^上传失败：(.*)$",
      "to": "アップロード失敗: $1"
    },
    {
      "re": "^恢复失败：(.*)$",
      "to": "復元失敗: $1"
    },
    {
      "re": "^目录加载失败：(.*)$",
      "to": "ディレクトリ読み込み失敗: $1"
    },
    {
      "re": "^路径验证失败：(.*)$",
      "to": "パス検証失敗: $1"
    },
    {
      "re": "^已复制 (\\d+) 条链接$",
      "to": "$1 件のリンクをコピーしました"
    },
    {
      "re": "^共找到 (\\d+) 个文件$",
      "to": "$1 件のファイルが見つかりました"
    },
    {
      "re": "^正在扫描目录：(.*)$",
      "to": "ディレクトリをスキャン中: $1"
    },
    {
      "re": "^重启失败：(.*)$",
      "to": "再起動失敗: $1"
    },
    {
      "re": "^连接失败：(.*)$",
      "to": "接続失敗: $1"
    },
    {
      "re": "^读取失败：(.*)$",
      "to": "読み取り失敗: $1"
    },
    {
      "re": "^输入发送失败：(.*)$",
      "to": "入力送信失敗: $1"
    },
    {
      "re": "^会话已结束，退出码：(.*)$",
      "to": "セッション終了、終了コード: $1"
    },
    {
      "re": "^综合配置已保存：(.*)$",
      "to": "総合設定を保存しました: $1"
    }
  ]
}
