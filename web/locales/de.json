      "re": "^运行中 \\| (.+) \\| ↓ (.+) · ↑ (.+) \\| 做种 ([0-9]+) · 下载 ([0-9]+) · 活跃 ([0-9]+) · 总计 ([0-9]+) · 连接 ([0-9]+) · DHT ([0-9]+)$",
      "to": "Läuft | $1 | ↓ $2 · ↑ $3 | Seeding $4 · Downloading $5 · Aktiv $6 · Gesamt $7 · Verbindungen $8 · DHT $9"
    },
    {
      "re": "^运行中 \\| (.+) \\| ↓ (.+) · ↑ (.+) \\| 做种 ([0-9]+) · 下载 ([0-9]+) · 活跃 ([0-9]+) · 总计 ([0-9]+) · 连接 ([0-9]+)$",
      "to": "Läuft | $1 | ↓ $2 · ↑ $3 | Seeding $4 · Downloading $5 · Aktiv $6 · Gesamt $7 · Verbindungen $8"
    },
    {
      "re": "^未运行 \\| (.+) \\| ↓ (.+) · ↑ (.+) \\| 做种 ([0-9]+) · 下载 ([0-9]+) · 活跃 ([0-9]+) · 总计 ([0-9]+) · 连接 ([0-9]+) · DHT ([0-9]+)$",
