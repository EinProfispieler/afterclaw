    {
      "re": "^路径：([^|]+) \\| 权限\\(([^)]+)\\) \\| 子目录 ([0-9]+) · 文件 ([0-9]+) \\| 可用 ([^|]+) / 总 ([^|]+) \\| 示例子目录：(.+)$",
      "to": "Pfad: $1 | Berechtigungen($2) | Unterverzeichnisse $3 · Dateien $4 | Verfügbar $5 / Gesamt $6 | Beispiel-Unterverzeichnisse: $7"
    },
    {
      "re": "^运行中 \\| (.+)$",
      "to": "Läuft | $1"
    },
    {
      "re": "^未运行 \\| (.+)$",
      "to": "Gestoppt | $1"
    },
    {
      "re": "^当前运行端口：([0-9]+)。 当前保存值与运行端口一致。$",
      "to": "Aktueller Laufzeit-Port: $1. Der gespeicherte Wert stimmt mit dem laufenden Port überein."
    },
    {
      "re": "^当前运行端口：([0-9]+)。 保存后需重启程序，重启后切换到：([0-9]+)。$",
      "to": "Aktueller Laufzeit-Port: $1. Nach dem Speichern und Neustart wird auf $2 gewechselt."
    },
    {
      "re": "^HTTP 配置已保存\\s+程序端口将在重启后切换为\\s*([0-9]+)。$",
