      "re": "^运行中 \\| 内置 DDNS \\| (.+)$",
      "to": "Läuft | Integriertes DDNS | $1"
    },
    {
      "re": "^未运行 \\| 内置 DDNS \\| (.+)$",
      "to": "Gestoppt | Integriertes DDNS | $1"
    },
