      "to": "$1 · v4 $2 / v6 $3 ($4s her)"
    },
    {
      "re": "^([A-Za-z0-9._-]+) · v4 (.+)（([0-9]+)s 前）$",
      "to": "$1 · v4 $2 ($3s her)"
