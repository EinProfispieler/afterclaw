  "patterns": [
    {
      "re": "^活跃 (\\d+) 个 · 最近完成 (\\d+) 个 · 总完成度 ([0-9.]+)%$",
      "to": "Aktiv $1 · Kürzlich abgeschlossen $2 · Gesamtfortschritt $3%"
    },
    {
      "re": "^来源速度：(.*)$",
      "to": "Quellgeschwindigkeiten: $1"
    },
    {
      "re": "^保存失败：(.*)$",
      "to": "Speichern fehlgeschlagen: $1"
    },
    {
      "re": "^配置加载失败：(.*)$",
      "to": "Konfiguration konnte nicht geladen werden: $1"
    },
    {
      "re": "^加载失败：(.*)$",
      "to": "Laden fehlgeschlagen: $1"
    },
    {
      "re": "^切换失败：(.*)$",
      "to": "Umschalten fehlgeschlagen: $1"
    },
    {
      "re": "^上传失败：(.*)$",
      "to": "Upload fehlgeschlagen: $1"
    },
    {
      "re": "^恢复失败：(.*)$",
      "to": "Zurücksetzen fehlgeschlagen: $1"
    },
    {
      "re": "^目录加载失败：(.*)$",
      "to": "Verzeichnis laden fehlgeschlagen: $1"
    },
    {
      "re": "^路径验证失败：(.*)$",
      "to": "Pfadprüfung fehlgeschlagen: $1"
    },
    {
      "re": "^已复制 (\\d+) 条链接$",
      "to": "$1 Links kopiert"
    },
    {
      "re": "^共找到 (\\d+) 个文件$",
      "to": "$1 Dateien gefunden"
    },
    {
      "re": "^正在扫描目录：(.*)$",
      "to": "Verzeichnis wird gescannt: $1"
    },
    {
      "re": "^重启失败：(.*)$",
      "to": "Neustart fehlgeschlagen: $1"
    },
    {
      "re": "^连接失败：(.*)$",
      "to": "Verbindung fehlgeschlagen: $1"
    },
    {
      "re": "^读取失败：(.*)$",
      "to": "Lesen fehlgeschlagen: $1"
    },
    {
      "re": "^输入发送失败：(.*)$",
      "to": "Eingabe senden fehlgeschlagen: $1"
    },
    {
      "re": "^会话已结束，退出码：(.*)$",
      "to": "Sitzung beendet, Exit-Code: $1"
    },
    {
      "re": "^综合配置已保存：(.*)$",
      "to": "Allgemeine Einstellungen gespeichert: $1"
    }
  ]
