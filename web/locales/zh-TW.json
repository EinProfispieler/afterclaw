  "patterns": [
    {
      "re": "^活跃 (\\d+) 个 · 最近完成 (\\d+) 个 · 总完成度 ([0-9.]+)%$",
      "to": "活躍 $1 個 · 最近完成 $2 個 · 總完成度 $3%"
    },
    {
      "re": "^来源速度：模块已关闭$",
      "to": "來源速度：模組已關閉"
    },
    {
      "re": "^来源速度获取失败$",
      "to": "來源速度取得失敗"
    },
    {
      "re": "^保存失败：(.*)$",
      "to": "儲存失敗：$1"
    },
    {
      "re": "^配置加载失败：(.*)$",
      "to": "設定載入失敗：$1"
    },
    {
      "re": "^加载失败：(.*)$",
      "to": "載入失敗：$1"
    },
    {
      "re": "^切换失败：(.*)$",
      "to": "切換失敗：$1"
    },
    {
      "re": "^上传失败：(.*)$",
      "to": "上傳失敗：$1"
    },
    {
      "re": "^恢复失败：(.*)$",
      "to": "恢復失敗：$1"
    },
    {
      "re": "^目录加载失败：(.*)$",
      "to": "目錄載入失敗：$1"
    },
    {
      "re": "^路径验证失败：(.*)$",
      "to": "路徑驗證失敗：$1"
    },
    {
      "re": "^已复制 (\\d+) 条链接$",
      "to": "已複製 $1 條連結"
    },
    {
      "re": "^共找到 (\\d+) 个文件$",
      "to": "共找到 $1 個檔案"
    },
    {
      "re": "^已进入目录：(.*)$",
      "to": "已進入目錄：$1"
    },
    {
      "re": "^已跳转目录：(.*)$",
      "to": "已跳轉目錄：$1"
    },
    {
      "re": "^已返回目录：(.*)$",
      "to": "已返回目錄：$1"
    },
    {
      "re": "^已复制目录名：(.*)$",
      "to": "已複製目錄名：$1"
    },
    {
      "re": "^外网上传已(开启|关闭)$",
      "to": "外網上傳已$1"
    },
    {
      "re": "^重启失败：(.*)$",
      "to": "重啟失敗：$1"
    },
    {
      "re": "^删除失败：(.*)$",
      "to": "刪除失敗：$1"
    },
    {
      "re": "^连接失败：(.*)$",
      "to": "連線失敗：$1"
    },
    {
      "re": "^读取失败：(.*)$",
      "to": "讀取失敗：$1"
    },
    {
      "re": "^输入发送失败：(.*)$",
      "to": "輸入傳送失敗：$1"
    },
    {
      "re": "^会话已结束，退出码：(.*)$",
      "to": "工作階段已結束，退出碼：$1"
    }
  ]
