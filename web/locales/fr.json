  "patterns": [
    {
      "re": "^活跃 (\\d+) 个 · 最近完成 (\\d+) 个 · 总完成度 ([0-9.]+)%$",
      "to": "Actifs $1 · Récemment terminés $2 · Progression globale $3%"
    },
    {
      "re": "^来源速度：(.*)$",
      "to": "Vitesses par source : $1"
    },
    {
      "re": "^保存失败：(.*)$",
      "to": "Échec de l'enregistrement : $1"
    },
    {
      "re": "^配置加载失败：(.*)$",
      "to": "Échec du chargement de la configuration : $1"
    },
    {
      "re": "^加载失败：(.*)$",
      "to": "Échec du chargement : $1"
    },
    {
      "re": "^切换失败：(.*)$",
      "to": "Échec du basculement : $1"
    },
    {
      "re": "^上传失败：(.*)$",
      "to": "Échec de l'envoi : $1"
    },
    {
      "re": "^恢复失败：(.*)$",
      "to": "Échec de la réinitialisation : $1"
    },
    {
      "re": "^目录加载失败：(.*)$",
      "to": "Échec du chargement du répertoire : $1"
    },
    {
      "re": "^路径验证失败：(.*)$",
      "to": "Échec de validation du chemin : $1"
    },
    {
      "re": "^已复制 (\\d+) 条链接$",
      "to": "$1 liens copiés"
    },
    {
      "re": "^共找到 (\\d+) 个文件$",
      "to": "$1 fichiers trouvés"
    },
    {
      "re": "^正在扫描目录：(.*)$",
      "to": "Analyse du répertoire : $1"
    },
    {
      "re": "^重启失败：(.*)$",
      "to": "Échec du redémarrage : $1"
    },
    {
      "re": "^连接失败：(.*)$",
      "to": "Échec de connexion : $1"
    },
    {
      "re": "^读取失败：(.*)$",
      "to": "Échec de lecture : $1"
    },
    {
      "re": "^输入发送失败：(.*)$",
      "to": "Échec d'envoi de saisie : $1"
    },
    {
      "re": "^会话已结束，退出码：(.*)$",
      "to": "Session terminée, code de sortie : $1"
    },
    {
      "re": "^综合配置已保存：(.*)$",
      "to": "Configuration générale enregistrée : $1"
    }
  ]
}
