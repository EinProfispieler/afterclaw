  "patterns": [
    {
      "re": "^活跃 (\\d+) 个 · 最近完成 (\\d+) 个 · 总完成度 ([0-9.]+)%$",
      "to": "Active $1 · Recently completed $2 · Overall $3%"
    },
    {
      "re": "^来源速度：(.*)$",
      "to": "Source speeds: $1"
    },
    {
      "re": "^保存失败：(.*)$",
      "to": "Save failed: $1"
    },
    {
      "re": "^配置加载失败：(.*)$",
